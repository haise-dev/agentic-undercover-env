# ── Database ─────────────────────────────────────────────────────
# PostgreSQL connection string for the API service
DATABASE_URL=postgresql+asyncpg://aue_user:aue_password@postgres:5432/aue_db

# ── Redis ─────────────────────────────────────────────────────────
# Redis connection URL for pub/sub and ephemeral state
REDIS_URL=redis://redis:6379/0

# ── LLM Provider API Keys ─────────────────────────────────────────
# At least ONE of the following must be set to run AI agents.
# Get free keys: groq.com | aistudio.google.com | platform.openai.com | platform.deepseek.com
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# ── API Service ───────────────────────────────────────────────────
# Host and port for the FastAPI service (internal Docker network)
API_HOST=0.0.0.0
API_PORT=8000

# ── Frontend Service ──────────────────────────────────────────────
# Public URL of the API (used by browser for WebSocket connections)
# In Docker: http://localhost:8000 | In production: https://your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Development Flags ─────────────────────────────────────────────
# Set to "development" or "production"
APP_ENV=development
# Enable verbose SQL query logging (true/false)
SQL_ECHO=false
